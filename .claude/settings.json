{
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git checkout *)",
      "Bash(gh pr create *)",
      "Write(src/content/**)",
      "Write(src/assets/digest/**)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Edit(src/content/**)",
      "mcp__tavily-mcp__*",
      "mcp__replicate__*"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(cat .env*)",
      "Bash(cat **/.env*)",
      "Bash(head .env*)",
      "Bash(head **/.env*)",
      "Bash(tail .env*)",
      "Bash(tail **/.env*)",
      "Bash(type .env*)",
      "Bash(type **/.env*)",
      "Read(.env*)",
      "Read(**/.env*)",
      "Read(./secrets/**)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | gsub(\"\\\\\\\\\"; \"/\")' | xargs npx prettier --write 2>/dev/null; exit 0"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pipeline-log.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-article.sh\""
          }
        ]
      }
    ]
  }
}
